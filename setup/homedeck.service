[Unit]
Description=HomeDeck FastAPI Server
After=network.target

[Service]
WorkingDirectory=/home/pi/Documents/HomeDeck/homedeck/backend
ExecStart=/home/pi/Documents/HomeDeck/homedeck/backend/venv/bin/uvicorn api:app --host 0.0.0.0 --port 8000
Restart=always
User=pi

[Install]
WantedBy=multi-user.target
